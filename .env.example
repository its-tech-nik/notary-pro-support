# Web3Forms (https://web3forms.com) — δημιουργείς δωρεάν access key και δηλώνεις ποιο email θα λαμβάνει τα μηνύματα.
# Μετατρέπεται σε PUBLIC_* στο Astro build.
PUBLIC_WEB3FORMS_ACCESS_KEY=

# Προαιρετικό: χρησιμοποιείται μόνο ως mailto fallback όταν ΔΕΝ έχει οριστεί το παραπάνω κλειδί.
PUBLIC_CONTACT_EMAIL=info@notary-pro-support.gr
