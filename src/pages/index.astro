---
import BaseLayout from "../layouts/BaseLayout.astro";
import PrivacyConsent from "../components/PrivacyConsent.astro";

const home = import.meta.env.BASE_URL;
/** Web3Forms — δημιουργία κλειδιού στο https://web3forms.com (δωρεάν, email παραλήπτη από εκεί) */
const web3AccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? "";
const mailtoFallback = import.meta.env.PUBLIC_CONTACT_EMAIL ?? "notaries.assists@gmail.com";
---

<BaseLayout title="NOTARY PRO SUPPORT O.E. | Επαγγελματική Υποστήριξη Συμβολαιογραφείων">
	<header class="site-header">
		<div class="header-inner">
			<a href={home} class="logo">
				<span class="logo-mark" aria-hidden="true">
					<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
						<rect x="4" y="6" width="32" height="28" rx="2" stroke="currentColor" stroke-width="1.5"></rect>
						<path d="M12 14h16M12 20h12M12 26h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
					</svg>
				</span>
				<span class="logo-text">NOTARY PRO SUPPORT</span>
			</a>
			<nav class="nav" aria-label="Κύρια πλοήγηση">
				<a href="#values">Οι Αξίες μας</a>
				<a href="#services">Υπηρεσίες</a>
				<a href="#notaries">Συμβολαιογράφοι</a>
				<a href="#lawyers">Δικηγόροι</a>
				<a href="#about">Εταιρεία</a>
				<a href="#contact" class="nav-cta">Επικοινωνία</a>
			</nav>
			<button type="button" class="menu-toggle" aria-expanded="false" aria-controls="mobile-nav" id="menu-toggle">
				<span class="sr-only">Μενού</span>
				<span class="menu-bar"></span>
				<span class="menu-bar"></span>
				<span class="menu-bar"></span>
			</button>
		</div>
		<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
			<a href="#values">Οι Αξίες μας</a>
			<a href="#services">Υπηρεσίες</a>
			<a href="#notaries">Συμβολαιογράφοι</a>
			<a href="#lawyers">Δικηγόροι</a>
			<a href="#about">Εταιρεία</a>
			<a href="#contact">Επικοινωνία</a>
		</div>
	</header>

	<div
		class="mobile-nav-backdrop"
		id="mobile-nav-backdrop"
		aria-hidden="true"
		tabindex="-1"
	></div>

	<section
		class="hero"
		aria-labelledby="hero-title"
		style={`--hero-photo: url(${home}new_image.png)`}
	>
		<div class="hero-bg"></div>
		<div class="hero-overlay"></div>
		<div class="hero-content">
			<p class="hero-tagline">your team for pro support…</p>
			<h1 id="hero-title" class="hero-title">
				Επαγγελματική υποστήριξη για συμβολαιογραφεία &amp; δικηγορικά γραφεία
			</h1>
			<p class="hero-sub">Αξιόπιστες λύσεις για τον συμβολαιογραφικό και νομικό χώρο</p>
			<a href="#contact" class="btn btn-primary">Επικοινωνήστε μαζί μας</a>
		</div>
	</section>

	<section id="values" class="section values" aria-labelledby="values-title">
		<div class="container">
			<h2 id="values-title" class="sr-only">Γιατί μας εμπιστεύονται</h2>
			<div class="values-grid">
				<article class="value-card">
					<div class="value-icon" aria-hidden="true">
						<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M24 4L6 12v12c0 11 8 20 18 22 10-2 18-11 18-22V12L24 4z" stroke="currentColor" stroke-width="2"/><path d="M18 24l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
					</div>
					<h3 class="value-heading">Εμπειρία &amp; εμπιστοσύνη</h3>
					<p class="value-text">Έμπειρη υποστήριξη για συμβολαιογράφους και νομικούς επαγγελματίες.</p>
				</article>
				<article class="value-card">
					<div class="value-icon" aria-hidden="true">
						<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="16" cy="28" r="8" stroke="currentColor" stroke-width="2"/><circle cx="32" cy="28" r="8" stroke="currentColor" stroke-width="2"/><circle cx="24" cy="16" r="8" stroke="currentColor" stroke-width="2"/></svg>
					</div>
					<h3 class="value-heading">Αποτελεσματικές λύσεις</h3>
					<p class="value-text">Οργάνωση γραφείου και διαδικασιών με σαφήνεια και ταχύτητα.</p>
				</article>
				<article class="value-card">
					<div class="value-icon" aria-hidden="true">
						<svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M24 4L6 12v12c0 11 8 20 18 22 10-2 18-11 18-22V12L24 4z" stroke="currentColor" stroke-width="2"/><rect x="18" y="20" width="12" height="10" rx="1" stroke="currentColor" stroke-width="2"/></svg>
					</div>
					<h3 class="value-heading">Εμπιστευτικότητα</h3>
					<p class="value-text">Ασφαλείς και διακριτικές υπηρεσίες σε κάθε συνεργασία.</p>
				</article>
			</div>
		</div>
	</section>

	<section id="services" class="section services-intro">
		<div class="container narrow">
			<div class="section-head">
				<h2 class="section-title gold-lines">Οι υπηρεσίες μας</h2>
				<p class="section-lead">Ολοκληρωμένη υποστήριξη για τη συμβολαιογραφική και νομική σας πράξη</p>
			</div>
			<p class="services-blurb">
				Οι υπηρεσίες μας απευθύνονται σε <strong>συμβολαιογράφους</strong> και <strong>δικηγόρους</strong>. Επιλέξτε παρακάτω την κατηγορία που σας ενδιαφέρει για λεπτομερή περιγραφή.
			</p>
			<div class="audience-cards">
				<a href="#notaries" class="audience-card">
					<span class="audience-label">Για</span>
					<span class="audience-title">Συμβολαιογράφους</span>
					<span class="audience-desc">Συγγραφή πράξεων, myProperty, Κτηματολόγιο και πλήρης υποστήριξη γραφείου.</span>
				</a>
				<a href="#lawyers" class="audience-card">
					<span class="audience-label">Για</span>
					<span class="audience-title">Δικηγόρους</span>
					<span class="audience-desc">Σύνταξη πράξεων, δηλώσεις, τεκμηρίωση και δακτυλογράφηση.</span>
				</a>
			</div>
		</div>
	</section>

	<section id="notaries" class="section service-block service-block--light" aria-labelledby="notaries-title">
		<div class="container">
			<header class="service-block-head">
				<p class="service-audience">Συμβολαιογράφοι</p>
				<h2 id="notaries-title" class="service-block-title">Υπηρεσίες προς συμβολαιογράφους</h2>
				<p class="service-block-lead">
					Επαγγελματική υποστήριξη συμβολαιογραφείων με έμφαση στη συγγραφή συμβολαιογραφικών πράξεων, τις ηλεκτρονικές δηλώσεις και τη διαχείριση ακινήτων και εταιρικών συναλλαγών.
				</p>
			</header>

			<div class="service-subsection">
				<h3 class="h3">Συγγραφή συμβολαιογραφικών πράξεων</h3>
				<ul class="service-list">
					<li>Δήλωση αποδοχής κληρονομιάς</li>
					<li>Γονική παροχή και δωρεά</li>
					<li>Σύσταση οριζόντιας και κάθετης ιδιοκτησίας</li>
					<li>Τροποποίηση οριζόντιας και κάθετης ιδιοκτησίας</li>
					<li>Εργολαβικά προσύμφωνα</li>
					<li>Προσύμφωνα αγοραπωλησίας/γονικής/δωρεάς</li>
					<li>Συνενώσεις – κατατμήσεις ακινήτων</li>
					<li>Διανομή</li>
					<li>Ανταλλαγή</li>
					<li>Σύσταση εταιρειών</li>
					<li>Τροποποιήσεις εταιρειών (μετατροπές, συγχωνεύσεις, διασπάσεις)</li>
					<li>Ανταλλαγή εταιρικών μεριδίων</li>
					<li>Πώληση εταιρικών μεριδίων</li>
					<li>Δωρεά εταιρικών μεριδίων</li>
					<li>Δήλωση του Ν. 1221/1981</li>
					<li>Διορθώσεις συμβολαιογραφικών πράξεων</li>
				</ul>
			</div>

			<div class="service-subsection">
				<h3 class="h3">Δηλώσεις myProperty και μέσω αιτημάτων</h3>
				<ul class="service-list">
					<li>Κληρονομιάς (κινητών και ακινήτων)</li>
					<li>Γονικών παροχών και δωρεών (κινητών και ακινήτων)</li>
					<li>Πώλησης</li>
					<li>Σύστασης οριζόντιας και κάθετης ιδιοκτησίας</li>
					<li>Τροποποίησης οριζόντιας και κάθετης ιδιοκτησίας</li>
					<li>Διανομής</li>
					<li>Χρησικτησίας</li>
				</ul>
			</div>

			<div class="service-subsection">
				<h3 class="h3">Λοιπές υπηρεσίες</h3>
				<ul class="service-list service-list--inline">
					<li>Υπολογισμός αντικειμενικών αξιών</li>
					<li>Περιλήψεις και καταχωρίσεις Κτηματολογίου</li>
					<li>Σύνταξη αίτησης και περίληψης μη λειτουργούντος Κτηματολογίου</li>
				</ul>
			</div>
		</div>
	</section>

	<section id="lawyers" class="section service-block service-block--muted" aria-labelledby="lawyers-title">
		<div class="container">
			<header class="service-block-head">
				<p class="service-audience">Δικηγόροι</p>
				<h2 id="lawyers-title" class="service-block-title">Υπηρεσίες προς δικηγόρους</h2>
				<p class="service-block-lead">
					Υποστήριξη νομικών γραφείων με σύνταξη πράξεων αποδοχής κληρονομιάς, δηλώσεις myProperty, τεκμηρίωση ακινήτων και δακτυλογράφηση.
				</p>
			</header>

			<div class="service-subsection">
				<h3 class="h3">Σύνταξη πράξεων αποδοχής κληρονομιάς</h3>
			</div>

			<div class="service-subsection">
				<h3 class="h3">Δηλώσεις myProperty και μέσω αιτημάτων</h3>
				<ul class="service-list">
					<li>Κληρονομιάς (κινητών και ακινήτων)</li>
					<li>Γονικών παροχών και δωρεών (κινητών και ακινήτων)</li>
					<li>Πώλησης</li>
					<li>Διανομής</li>
					<li>Χρησικτησίας</li>
				</ul>
			</div>

			<div class="service-subsection">
				<h3 class="h3">Λοιπές υπηρεσίες</h3>
				<ul class="service-list service-list--inline">
					<li>Υπολογισμός αντικειμενικών αξιών</li>
					<li>Περιλήψεις και καταχωρίσεις Κτηματολογίου</li>
					<li>Σύνταξη αίτησης και περίληψης μη λειτουργούντος Κτηματολογίου</li>
					<li>Δακτυλογράφηση κειμένων</li>
				</ul>
			</div>
		</div>
	</section>

	<section id="about" class="section about" aria-labelledby="about-title">
		<div class="container">
			<div class="section-head">
				<h2 id="about-title" class="section-title gold-lines">Η εταιρεία μας</h2>
				<p class="section-lead">NOTARY PRO SUPPORT O.E.</p>
			</div>
			<div class="about-grid">
				<div class="about-text">
					<p>
						Η <strong>NOTARY PRO SUPPORT O.E.</strong> ιδρύθηκε τον Νοέμβριο του 2025 και αποτελείται από καταξιωμένες και έμπειρες επαγγελματίες, με εξειδικευμένες γνώσεις στον τομέα της συμβολαιογραφικής υποστήριξης και παροχές υψηλής ποιότητας.
					</p>
					<p>
						Η αποστολή μας είναι να προσφέρουμε ολοκληρωμένη και αξιόπιστη υποστήριξη σε κάθε επαγγελματική διαδικασία, με απόλυτη συνέπεια, ασφάλεια και διακριτικότητα. Η ομάδα μας συνδυάζει πολυετή εμπειρία με τεχνογνωσία, ώστε να διευκολύνει την καθημερινή σας εργασία.
					</p>
					<p>
						Κάθε συνεργασία αντιμετωπίζεται με εξατομικευμένη προσέγγιση. Πιστεύουμε ότι η ποιότητα, η αξιοπιστία και η επαγγελματική ακεραιότητα είναι η βάση για μακροχρόνιες συνεργασίες — είμαστε εδώ ώστε κάθε διαδικασία να ολοκληρώνεται σωστά, έγκαιρα και με επαγγελματισμό.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section why" aria-labelledby="why-title">
		<div class="container narrow">
			<div class="section-head">
				<h2 id="why-title" class="section-title section-title--on-dark gold-lines">Γιατί να μας επιλέξετε</h2>
			</div>
			<ul class="why-list">
				<li>Ανώτατη επαγγελματική αξιοπιστία — ακρίβεια, συνέπεια και διακριτικότητα σε κάθε υπηρεσία.</li>
				<li>Εξειδικευμένη ομάδα με εμπειρία και τεχνογνωσία, με λύσεις προσαρμοσμένες στις ανάγκες σας.</li>
				<li>Ολοκληρωμένη υποστήριξη από την οργάνωση έως την εκτέλεση, ώστε εσείς να εστιάζετε στην ουσία της δουλειάς σας.</li>
				<li>Ασφάλεια και διαφάνεια — κάθε διαδικασία με πλήρη σεβασμό στην εμπιστευτικότητα.</li>
			</ul>
			<p class="why-closing">
				Στην NOTARY PRO SUPPORT η δέσμευσή μας είναι ξεκάθαρη: υποστήριξη υψηλής ποιότητας που συνδυάζει επαγγελματισμό, ασφάλεια και αποτελεσματικότητα.
			</p>
			<p class="why-closing">Είμαστε ο συνεργάτης που μπορείτε να εμπιστευτείτε σε κάθε στάδιο των διαδικασιών σας.</p>
		</div>
	</section>

	<section id="contact" class="section contact" aria-labelledby="contact-title">
		<div class="container">
			<div class="section-head">
				<h2 id="contact-title" class="section-title gold-lines">Επικοινωνία</h2>
			</div>
			<div class="contact-grid">
				<div class="contact-card">
					<h3 class="contact-card-title">Στοιχεία</h3>
					<dl class="contact-dl">
						<dt>Επωνυμία</dt>
						<dd>NOTARY PRO SUPPORT O.E.</dd>
						<dt>Διεύθυνση</dt>
						<dd>
							Γ. Κονδύλη 13<br />
							Πολύκαστρο Παιονίας, Κιλκίς<br />
							Τ.Κ. 61200
						</dd>
						<dt>Τηλέφωνα</dt>
						<dd>
							<a href="tel:+306978216636">697 821 6636</a><br />
							<a href="tel:+306945696233">694 569 6233</a>
						</dd>
						<dt>Email</dt>
						<dd><a href="mailto:notaries.assists@gmail.com">notaries.assists@gmail.com</a></dd>
					</dl>
				</div>
				<div class="contact-card contact-form-card">
					<h3 class="contact-card-title">Φόρμα επικοινωνίας</h3>
					<p class="form-hint">
						Συμπληρώστε τα πεδία και πατήστε αποστολή.
						{web3AccessKey
							? " Το μήνυμα στέλνεται απευθείας στην εταιρεία."
							: " Αν δεν έχει ρυθμιστεί η ηλεκτρονική αποστολή, θα ανοίξει το πρόγραμμα αλληλογραφίας σας."}
					</p>
					<p class="form-status" id="form-status" role="status" aria-live="polite"></p>
					<form class="contact-form" id="contact-form">
						<label class="form-field">
							<span>Ονοματεπώνυμο</span>
							<input type="text" name="name" required autocomplete="name" />
						</label>
						<label class="form-field">
							<span>Email</span>
							<input type="email" name="email" required autocomplete="email" />
						</label>
						<label class="form-field">
							<span>Μήνυμα</span>
							<textarea name="message" rows="5" required></textarea>
						</label>
						<button type="submit" class="btn btn-primary btn-full" id="form-submit">Αποστολή</button>
					</form>
				</div>
			</div>
		</div>
	</section>

	<footer class="site-footer">
		<div class="container footer-inner">
			<p class="footer-brand">NOTARY PRO SUPPORT O.E.</p>
			<p class="footer-legal">
				<a href="#privacy-policy" data-open-privacy class="footer-legal-link">Πολιτική απορρήτου &amp; προσωπικά δεδομένα</a>
			</p>
			<p class="footer-copy">© {new Date().getFullYear()} · Με επιφύλαξη παντός δικαιώματος.</p>
		</div>
	</footer>

	<PrivacyConsent />

	<script define:vars={{ web3AccessKey, mailtoFallback }}>
		const toggle = document.getElementById("menu-toggle");
		const mobileNav = document.getElementById("mobile-nav");
		const mobileNavBackdrop = document.getElementById("mobile-nav-backdrop");
		function closeMobileNav() {
			mobileNav?.classList.remove("mobile-nav--open");
			mobileNav?.setAttribute("aria-hidden", "true");
			toggle?.setAttribute("aria-expanded", "false");
			mobileNavBackdrop?.classList.remove("mobile-nav-backdrop--open");
			mobileNavBackdrop?.setAttribute("aria-hidden", "true");
			document.body.style.overflow = "";
		}
		function openMobileNav() {
			mobileNav?.classList.add("mobile-nav--open");
			mobileNav?.setAttribute("aria-hidden", "false");
			toggle?.setAttribute("aria-expanded", "true");
			mobileNavBackdrop?.classList.add("mobile-nav-backdrop--open");
			mobileNavBackdrop?.setAttribute("aria-hidden", "false");
			document.body.style.overflow = "hidden";
		}
		toggle?.addEventListener("click", () => {
			if (mobileNav?.classList.contains("mobile-nav--open")) closeMobileNav();
			else openMobileNav();
		});
		mobileNavBackdrop?.addEventListener("click", () => closeMobileNav());
		window.matchMedia("(min-width: 900px)").addEventListener("change", (e) => {
			if (e.matches) closeMobileNav();
		});
		/** Section tops include large padding; align the visible heading block under the closed toolbar */
		function resolveScrollAnchor(section) {
			if (!(section instanceof HTMLElement)) return section;
			const inner =
				section.querySelector(".service-block-head") ||
				section.querySelector(".section-head") ||
				section.querySelector(".values-grid");
			return inner ?? section;
		}

		mobileNav?.querySelectorAll('a[href^="#"]').forEach((a) => {
			a.addEventListener("click", (e) => {
				const href = a.getAttribute("href");
				if (!href || href.length < 2) return;
				const id = href.slice(1);
				const target = document.getElementById(id);
				if (!target) return;
				e.preventDefault();
				closeMobileNav();
				const smooth = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
				const anchor = resolveScrollAnchor(target);
				let scrolled = false;
				const scrollPastClosedHeader = () => {
					if (scrolled) return;
					scrolled = true;
					const headerBar = document.querySelector(".header-inner");
					const headerH = headerBar?.getBoundingClientRect().height ?? 0;
					const gap = 6;
					const y = anchor.getBoundingClientRect().top + window.scrollY - headerH - gap;
					window.scrollTo({ top: Math.max(0, y), behavior: smooth ? "smooth" : "auto" });
					history.replaceState(null, "", href);
				};
				const onNavTransitionEnd = (ev) => {
					if (ev.target !== mobileNav || ev.propertyName !== "max-height") return;
					mobileNav.removeEventListener("transitionend", onNavTransitionEnd);
					window.clearTimeout(fallbackTimer);
					requestAnimationFrame(scrollPastClosedHeader);
				};
				const fallbackTimer = window.setTimeout(() => {
					mobileNav?.removeEventListener("transitionend", onNavTransitionEnd);
					requestAnimationFrame(scrollPastClosedHeader);
				}, 450);
				if (mobileNav) mobileNav.addEventListener("transitionend", onNavTransitionEnd);
				else requestAnimationFrame(scrollPastClosedHeader);
			});
		});
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && mobileNav?.classList.contains("mobile-nav--open")) closeMobileNav();
		});

		const form = document.getElementById("contact-form");
		const formStatus = document.getElementById("form-status");
		const submitBtn = document.getElementById("form-submit");

		form?.addEventListener("submit", async (e) => {
			e.preventDefault();
			if (!(form instanceof HTMLFormElement)) return;
			formStatus && (formStatus.textContent = "");
			if (!form.checkValidity()) {
				form.reportValidity();
				return;
			}
			const fd = new FormData(form);
			const name = String(fd.get("name") || "").trim();
			const email = String(fd.get("email") || "").trim();
			const message = String(fd.get("message") || "").trim();

			if (!web3AccessKey) {
				const subject = encodeURIComponent(`Επικοινωνία ιστοσελίδας — ${name}`);
				const body = encodeURIComponent(
					`Ονοματεπώνυμο: ${name}\nEmail: ${email}\n\nΜήνυμα:\n${message}`
				);
				window.location.href = `mailto:${mailtoFallback}?subject=${subject}&body=${body}`;
				return;
			}

			if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = true;
			try {
				const res = await fetch("https://api.web3forms.com/submit", {
					method: "POST",
					headers: { "Content-Type": "application/json", Accept: "application/json" },
					body: JSON.stringify({
						access_key: web3AccessKey,
						subject: `Επικοινωνία ιστοσελίδας — ${name}`,
						name,
						email,
						message,
					}),
				});
				const data = await res.json();
				if (data && typeof data === "object" && "success" in data && data.success) {
					if (formStatus) {
						formStatus.textContent =
							"Το μήνυμα στάλθηκε επιτυχώς. Θα επικοινωνήσουμε σύντομα.";
						formStatus.className = "form-status form-status--ok";
					}
					form.reset();
				} else {
					const msg =
						data && typeof data === "object" && "message" in data && typeof data.message === "string"
							? data.message
							: "Αποτυχία αποστολής";
					throw new Error(msg);
				}
			} catch {
				if (formStatus) {
					formStatus.textContent =
						"Δεν ήταν δυνατή η αποστολή. Δοκιμάστε ξανά ή καλέστε μας τηλεφωνικά.";
					formStatus.className = "form-status form-status--err";
				}
			} finally {
				if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = false;
			}
		});
	</script>
</BaseLayout>

